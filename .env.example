# Infrastructure
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:nexus_dev_password@postgres:5432/nexus

QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=nexus
MINIO_ROOT_PASSWORD=nexus_dev_secret
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false

# LLM
GEMINI_API_KEY=your_gemini_api_key_here

# Security
JWT_SECRET=super_secret_dev_key_change_in_production
JWT_ALGORITHM=HS256

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=console
GRAFANA_PASSWORD=admin
